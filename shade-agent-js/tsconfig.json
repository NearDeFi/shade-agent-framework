{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "strict": false,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2021"],
    "types": ["node"],
    // Silences TS5101 (`baseUrl` deprecated) emitted from tsup's internal
    // dts pipeline. Revisit when bumping TypeScript past 7.0.
    "ignoreDeprecations": "6.0"
  },
  "include": ["src", "tests"],
  "exclude": ["node_modules", "dist"]
}
