{
  "name": "@neardefi/shade-agent-cli",
  "version": "2.4.0",
  "description": "A CLI for deploying Shade Agents",
  "author": "Matt Lockyer <github.com/mattlockyer>",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "dist/src/cli.js",
  "bin": {
    "shade": "dist/src/cli.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NearDeFi/shade-agent-framework.git",
    "directory": "shade-agent-cli"
  },
  "scripts": {
    "build": "rm -rf dist && mkdir -p dist/src && cp -r src/* dist/src/",
    "prepublishOnly": "npm run build",
    "publish": "npm publish --access public",
    "test": "vitest run tests/unit",
    "test:coverage": "vitest run --coverage tests/unit"
  },
  "dependencies": {
    "@inquirer/confirm": "6.1.1",
    "@inquirer/input": "5.1.2",
    "@inquirer/password": "5.1.1",
    "@inquirer/select": "5.2.1",
    "@napi-rs/keyring": "1.3.0",
    "@near-js/accounts": "2.5.1",
    "@near-js/crypto": "2.5.1",
    "@near-js/providers": "2.5.1",
    "@near-js/signers": "2.5.1",
    "@near-js/tokens": "2.5.1",
    "@near-js/transactions": "2.5.1",
    "@phala/cloud": "0.3.0",
    "borsh": "2.0.0",
    "bs58": "6.0.0",
    "chalk": "5.6.2",
    "commander": "15.0.0",
    "random-words": "2.0.1",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.9",
    "vitest": "4.1.9"
  },
  "keywords": [
    "AI",
    "agents",
    "crypto",
    "shade",
    "near",
    "shade-agent"
  ]
}
